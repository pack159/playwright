{
  "default": {
    "paths": [
      "features/**/*.feature"
    ],
    "import": [
      "steps/**/*.ts",
      "support/**/*.ts"
    ],
    "formatOptions": {
      "snippetInterface": "async-await"
    },
    "format": [
      "progress-bar",
      "summary",
      "html:cucumber-report.html",
      "json:cucumber-report.json"
    ]
  }
}